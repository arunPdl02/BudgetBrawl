# ── JWT ──────────────────────────────────────────────────────────────────────
SECRET_KEY=change-me-generate-with-openssl-rand-hex-32
JWT_ALGORITHM=HS256
JWT_EXPIRY_MINUTES=1440

# ── URLs ─────────────────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:5173

# ── Google OAuth ─────────────────────────────────────────────────────────────
# Create credentials at https://console.cloud.google.com/apis/credentials
# Scopes: openid, email, profile, calendar.readonly
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/callback

# ── Snowflake ─────────────────────────────────────────────────────────────────
# Account format: <org>-<account>  (e.g. myorg-myaccount)
SNOWFLAKE_ACCOUNT=
SNOWFLAKE_USER=
SNOWFLAKE_PASSWORD=
SNOWFLAKE_DATABASE=BUDGETBRAWL_DB
SNOWFLAKE_SCHEMA=APP
SNOWFLAKE_WAREHOUSE=BUDGETBRAWL_WH
SNOWFLAKE_ROLE=BUDGETBRAWL_ROLE

# ── Encryption ────────────────────────────────────────────────────────────────
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=

# ── Frontend ──────────────────────────────────────────────────────────────────
VITE_API_BASE_URL=http://localhost:8000
